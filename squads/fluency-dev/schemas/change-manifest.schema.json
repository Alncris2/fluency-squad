{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/change-manifest.schema.json",
  "title": "Change Manifest (fluency-dev)",
  "type": "object",
  "required": ["run", "baseline", "changes", "surface", "risk_hints", "evidence"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["id", "squad", "generated_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{6}" },
        "squad": { "type": "string", "enum": ["fluency-dev"] },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "baseline": {
      "type": "object",
      "required": ["base_ref", "head_ref"],
      "properties": {
        "base_ref": { "type": "string", "description": "ex: origin/main" },
        "head_ref": { "type": "string", "description": "ex: HEAD" }
      }
    },
    "changes": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "status", "layer"],
            "properties": {
              "path": { "type": "string" },
              "status": { "type": "string", "enum": ["A", "M", "D", "R"] },
              "layer": { "type": "string", "enum": ["backend", "frontend", "infra", "docs", "unknown"] }
            }
          }
        },
        "migrations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "tables", "reversible_hint"],
            "properties": {
              "path": { "type": "string" },
              "tables": { "type": "array", "items": { "type": "string" } },
              "reversible_hint": { "type": "boolean" }
            }
          }
        }
      }
    },
    "surface": {
      "type": "object",
      "required": ["api", "frontend"],
      "properties": {
        "api": {
          "type": "array",
          "description": "operacoes HTTP impactadas",
          "items": {
            "type": "object",
            "required": ["method", "path"],
            "properties": {
              "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "path": { "type": "string" },
              "auth": {
                "type": "object",
                "required": ["required", "scheme"],
                "properties": {
                  "required": { "type": "boolean" },
                  "scheme": { "type": "string", "enum": ["bearer", "cookie", "basic", "unknown"] }
                }
              },
              "handler_hint": { "type": "string" },
              "request_shape_hint": {
                "type": "object",
                "properties": {
                  "content_types": { "type": "array", "items": { "type": "string" } },
                  "fields": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "frontend": {
          "type": "object",
          "required": ["routes", "components_changed", "testids"],
          "properties": {
            "routes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "type": "string" },
                  "component_hint": { "type": "string" },
                  "guards_hint": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "components_changed": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string" },
                  "selector_hint": { "type": "string" }
                }
              }
            },
            "testids": {
              "type": "array",
              "description": "data-testid impactados ou recomendados",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "risk_hints": {
      "type": "object",
      "required": ["auth_touched", "validation_touched", "db_schema_touched", "streaming_touched"],
      "properties": {
        "auth_touched": { "type": "boolean" },
        "validation_touched": { "type": "boolean" },
        "db_schema_touched": { "type": "boolean" },
        "streaming_touched": { "type": "boolean" },
        "high_risk_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["git_diff_paths", "commands_run"],
      "properties": {
        "git_diff_paths": { "type": "array", "items": { "type": "string" } },
        "commands_run": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
